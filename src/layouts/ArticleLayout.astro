---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  publishDate?: string;
}

const { title, description, publishDate } = Astro.props;

const pageTitle = `${title} – Augenoptik Pochert`;
---

<BaseLayout title={pageTitle} description={description}>
  <article class="article-container text-container">
    <header class="article-header">
      <h1 class="article-title welcome-highlight-color">{title}</h1>
      {
        publishDate && (
          <time class="article-date" datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString("de-DE", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
        )
      }
    </header>
    <div class="article-body welcome-text">
      <slot />
    </div>
    <footer class="article-footer">
      <a href="/" class="back-link">← Zurück zur Startseite</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-container {
    max-width: 42rem;
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid rgb(var(--color-primary-rgb) / 0.2);
  }

  .article-title {
    font-size: 1.75rem;
    line-height: 1.25;
    margin-bottom: 0.75rem;

    @media (min-width: 640px) {
      font-size: 2rem;
    }

    @media (min-width: 1024px) {
      font-size: 2.25rem;
    }
  }

  .article-date {
    font-size: 0.85rem;
    color: #888;
    font-style: italic;
  }

  .article-body {
    :global(h2) {
      font-size: 1.35rem;
      color: #1675bf;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      line-height: 1.3;

      @media (min-width: 640px) {
        font-size: 1.5rem;
      }
    }

    :global(h3) {
      font-size: 1.1rem;
      color: #333;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    :global(ul),
    :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1rem;

      :global(li) {
        margin-bottom: 0.4rem;
      }
    }

    :global(a) {
      color: rgb(var(--color-primary-dark-rgb));
      text-underline-offset: 0.18em;
    }

    :global(a:hover) {
      text-underline-offset: 0.28em;
    }

    :global(strong) {
      font-weight: 600;
      color: #333;
    }
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .back-link {
    color: rgb(var(--color-primary-dark-rgb));
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: opacity 0.2s;

    &:hover {
      opacity: 0.75;
    }
  }
</style>
