---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Augenoptik Pochert - Der Optiker der für Sie Zeit hat",
  description = "Augenoptik Pochert in Freital - Der Optiker der für Sie Zeit hat. Individuelle Brillen, Sehtests, Kontaktlinsen und erstklassiger Service. Seit 1929.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preload" href="/images/Logo-Augenoptik-Pochert-1.avif" as="image" />
    <Font cssVariable="--font-alan-sans" preload />
  </head>
  <body>
    <Header />

    <slot />

    <Footer />
  </body>
</html>
