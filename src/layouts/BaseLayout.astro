---
import { Font, getImage } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import logoSrc from "../assets/logo.png";

const logoPreload = await getImage({ src: logoSrc, height: 100, format: "avif" });

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Augenoptik Pochert - Der Optiker der für Sie Zeit hat",
  description = "Augenoptik Pochert in Freital - Der Optiker der für Sie Zeit hat. Individuelle Brillen, Sehtests, Kontaktlinsen und erstklassiger Service. Seit 1929.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preload" href={logoPreload.src} as="image" type="image/avif" />
    <Font cssVariable="--font-alan-sans" preload />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>
