---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
---

<header class="header">
  <div class="header-container">
    <div class="logo">
      <a href="/">
        <Image src={logo} alt="Augenoptik Pochert Logo" height={100} format="avif" />
      </a>
    </div>
    <nav class="nav">
      <a href="/" class="nav-link">HOME</a>
      <a href="/#leistungen" class="nav-link">LEISTUNGEN</a>
      <a href="/#kontakt" class="nav-link">KONTAKT</a>
      <a href="/#oeffnungszeiten" class="nav-link">ÖFFNUNGSZEITEN</a>
      <a href="tel:+493516413017" class="nav-link phone">📞 (0351) 641 30 17</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-background);
    padding: 1rem;
    box-shadow: 0 4px 8px var(--color-shadow);
    z-index: 100;

    @media (min-width: 640px) {
      padding: 1.25rem 2rem;
    }

    @media (min-width: 1024px) {
      padding: 1.5rem 2rem;
    }
  }

  .header-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 2rem;

    @media (min-width: 640px) {
      padding-top: 0;
    }
  }

  .logo img {
    display: block;
    height: 85px;
    width: auto;

    @media (min-width: 1024px) {
      height: 100px;
    }
  }

  .nav {
    display: flex;
    gap: 0.5rem 0.35rem;

    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-nav-link);
    font-weight: 400;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    padding: 0.25rem 0.75rem;
    transition:
      color 0.3s,
      background-color 0.3s;
    border-radius: 3px;
    white-space: nowrap;

    @media (min-width: 640px) {
      font-size: 0.9rem;
    }

    &:active,
    &.active {
      color: var(--color-nav-link-active);
    }

    &.phone {
      color: var(--color-nav-link-active);
    }
  }
</style>
